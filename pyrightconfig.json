{
  "include": [
    "apps/api",
    "apps/worker",
    "apps/api_v2",
    "packages/shared",
    "packages/backend",
    "packages/blueprints",
    "packages/partners"
  ],
  "extraPaths": [
    "packages/shared",
    "packages/backend",
    "packages/blueprints",
    "packages/partners",
    "apps/api",
    "apps/worker",
    "apps/api_v2"
  ],
  "typeCheckingMode": "off",
  "reportMissingImports": false,
  "reportMissingTypeStubs": false,
  "reportUndefinedVariable": "warning",
  "reportUnusedVariable": "warning",
  "ignore": [
    "**/node_modules/**",
    "**/.venv/**",
    "**/venv/**",
    "**/__pycache__/**",
    "**/dist/**",
    "**/build/**",
    "**/*.spec.ts"
  ]
}