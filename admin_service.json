{
  "service": {
    "name": "jobhuntin-admin",
    "type": "static_site",
    "repo": "https://github.com/ranoli90/sorce",
    "branch": "main",
    "rootDir": "apps/web-admin",
    "buildCommand": "npm install && npm run build",
    "publishPath": "dist",
    "envVars": [
      {"key": "VITE_API_URL", "value": "https://jobhuntin-api.onrender.com"},
      {"key": "NODE_VERSION", "value": "20"}
    ],
    "autoDeploy": "yes"
  }
}
