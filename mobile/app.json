{
  "expo": {
    "name": "Sorce",
    "slug": "sorce",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": ["**/*"],
    "scheme": "sorce",
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#3B82F6",
      "androidMode": "default",
      "androidCollapsedTitle": "Sorce"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.sorce.mobile",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Sorce needs camera access to scan documents.",
        "NSPhotoLibraryUsageDescription": "Sorce needs photo library access to upload your resume.",
        "UIBackgroundModes": ["remote-notification"]
      },
      "associatedDomains": ["applinks:sorce.app"],
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "app.sorce.mobile",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "permissions": ["RECEIVE_BOOT_COMPLETED", "VIBRATE"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "sorce.app", "pathPrefix": "/invite" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6"
        }
      ],
      "expo-store-review"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "owner": "sorce-team"
  }
}
