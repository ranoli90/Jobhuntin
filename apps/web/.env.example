# ===========================================
# REQUIRED - Must be configured for the app to work
# ===========================================

# API URL - The backend API endpoint (REQUIRED for magic links to work)
VITE_API_URL=https://api.jobhuntin.com

# App base URL - Used for redirects and magic links
VITE_APP_BASE_URL=https://jobhuntin.com

# ===========================================
# OPTIONAL - Analytics & Features
# ===========================================

# Google Analytics 4 (GA4)
# Used in index.html and hooks/useGoogleAnalytics.ts
VITE_GA_ID=G-P1QLYH3M13

# Optional: Google Tag Manager
# VITE_GTM_ID=GTM-XXXXX

# Google Indexing API
# Requires a Service Account JSON Key (OAuth 2.0). 
# An API Key (AIza...) is NOT sufficient for URL submission.
# 1. Create Service Account in Google Cloud (IAM & Admin > Service Accounts)
# 2. Generate JSON Key
# 3. Enable "Web Search Indexing API"
# 4. Add service account email as Owner in Search Console
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account-key.json

# OR stick the raw JSON content here (for Render/CI envs):

# OpenRouter API Key (for competitor content generation)
# Get your key at https://openrouter.ai/keys
LLM_API_KEY=your-openrouter-api-key

# Sentry Error Tracking (H4: Frontend Error Tracking)
# Get your DSN from https://sentry.io/settings/projects/
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
