{
  "name": "sorce-web",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-sitemap.cjs",
    "build": "vite build",
    "build:full": "vite build && npx tsx scripts/seo/prerender.ts",
    "build:types": "tsc -b",
    "preview": "vite preview",
    "seo:prerender": "npx tsx scripts/seo/prerender.ts",
    "seo:generate": "npx tsx scripts/seo/generate-competitor-content.ts",
    "seo:submit": "npx tsx scripts/seo/submit-to-google.ts",
    "seo:submit-enhanced": "npx tsx scripts/seo/submit-to-google-enhanced.ts",
    "seo:generate-city": "npx tsx scripts/seo/generate-city-content.ts",
    "seo:engine": "npx tsx scripts/seo/automated-ranking-engine.ts",
    "seo:verify": "npx tsx scripts/seo/verify-google-indexing.ts",
    "seo:backend": "npx tsx scripts/seo/api-server.ts",
    "seo:monitor": "npx tsx scripts/seo/seo-monitoring-dashboard.ts",
    "seo:news": "npx tsx scripts/seo/news-monitor.ts",
    "seo:fast-index": "npx tsx scripts/seo/fast-index.ts",
    "seo:fast-index:dry": "npx tsx scripts/seo/fast-index.ts --dry-run",
    "seo:submit-all": "npx tsx scripts/seo/submit-all-urls.ts",
    "check-links": "npx linkinator http://localhost:5173 --recurse",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "audit:deps": "depcheck --ignores=@types/*,eslint-plugin-*,eslint-config-*",
    "audit:dead": "knip",
    "audit:tsc": "tsc --noEmit",
    "audit:npm": "npm audit --audit-level=moderate",
    "audit:a11y": "node scripts/audit-a11y.js",
    "audit:all": "npm run audit:tsc && npm run audit:deps && npm run audit:dead && npm run audit:npm"
  },
