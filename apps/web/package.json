    "@types/pg": "^8.16.0",
    "@types/quicklink": "^2.3.4",
    "@types/react": "18.2.43",
    "@types/react-dom": "18.2.17",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@types/testing-library__jest-dom": "^5.14.9",
