# =========================================================================
# SECURITY: These patterns prevent accidental secret commits.
# If you need to add a new secret file, add its pattern here FIRST.
# Secrets already in git history must be rotated — .gitignore only
# prevents future commits, it does NOT remove history.
# =========================================================================

# Environment files (NEVER commit secrets)
.env
.env.*
!.env.example

# Explicit subdirectory .env files (belt-and-suspenders)
apps/**/.env
packages/**/.env
scripts/**/.env
scripts/**/temp.env
*.env.local
*.env.*.local

# Service account keys (NEVER commit private keys)
**/service-account.json
**/service-account*.json
*.pem
*.p12
*.key

# Dependencies
node_modules/
__pycache__/
*.pyc
.pnp.cjs
.pnp.loader.mjs
.yarn/
.turbo/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
pip-wheel-metadata/
.parcel-cache/

# Expo / React Native artifacts
mobile/.expo/
mobile/.expo-shared/
*.expo/

# Build outputs
dist/
build/
.expo/
.expo-shared/
*.tsbuildinfo
.next/
.vercel/
.output/
playwright-report/
test-results/
coverage/
.coverage
coverage.xml
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo
.fleet/

# Databases / local state
*.sqlite
*.sqlite3
*.db
*.db-journal

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/
.nyc_output/

# Supabase local
supabase/.temp/

# Investor exports (may contain sensitive data)
investor-metrics/exports/
investor-data-room/exports/

# Setup scripts (contain API keys during provisioning)
scripts/setup/

# Analysis reports
*_report.json
*_report.pdf

# Credential files that may appear during development
**/credentials.json
**/client_secret*.json
**/*.pfx

# Sonar
sonar-report.json
.scannerwork/

# Archived one-off scripts (moved from repo root during cleanup)
_scripts_archive/

# Misc temporary files
*.tmp
*.temp
*.bak
*.orig

# Generated analysis/audit outputs (regenerate as needed)
analysis_output/
render_audit_results.json
audit-report-*.txt
audit-output.txt
ruff_errors.json
CODEBASE_AUDIT_REPORT.md
COMPREHENSIVE_PRODUCTION_READINESS_AUDIT.md
PRODUCTION_READINESS_AUDIT_REPORT.md
API_BUILD_FIX_SUMMARY.md
CRITICAL_FIX_REQUIRED.md
EMERGENCY_FIX.md
IMPLEMENTATION_SUMMARY.md

# Deployment / debug artifacts (contain service IDs, tokens, etc.)
deploy_check.json
deploy_history.json
latest_deploy.json
services.json
services_status.json
services_response.json
render_services.json
render_full.json
full_api_response.json
render_api_test_report.json
pooler_config.json
projects.json
service_config.json
admin_service.json
api_env.json
api_logs.json
final_config.json
minimal_config.json
simple_config.json
minimal_service.json
create_service.json
create_service_clean.json
phase15_audit_results.json
production_readiness_report.json
integration_test_report.json
deployment_status_summary.md
jobhuntin-job-sync-logs.json

# E2E test reports (Playwright)
jobhuntin-e2e-tests/reports/

# SEO script outputs
apps/web/fast_index_output.txt
apps/web/scripts/seo/.generation-tracking.json
