# ============================================================
# SORCE — Local Development Environment (Example)
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================================

# ── Environment ──────────────────────────────────────────────
ENV=local
LOG_JSON=false
LOG_LEVEL=DEBUG

# ── Database (Render PostgreSQL) ──────────────────────────────
DATABASE_URL=postgresql://jobhuntin_user:YOUR_PASSWORD@dpg-d66ck524d50c73bas62g-a:5432/jobhuntin

# ── Redis (Optional - for distributed rate limiting) ────────
# REDIS_URL=redis://your-redis-instance:6379/0

# ── LLM / OpenRouter ─────────────────────────────────────────
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-your-key
LLM_MODEL=google/gemma-2-9b-it:free

# ── Adzuna Job Board API ─────────────────────────────────────
ADZUNA_APP_ID=your-app-id
ADZUNA_API_KEY=your-api-key

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Render (for deploy scripts, CLI, maintenance) ──────────────
# RENDER_API_TOKEN=rnd_xxx  # From dashboard.render.com → Account → API Keys

# ── Security Secrets (generate with: python scripts/generate_secrets.py) ──
CSRF_SECRET=generate-with-python-scripts-generate-secrets-py
WEBHOOK_SIGNING_SECRET=generate-with-python-scripts-generate-secrets-py
SSO_SESSION_SECRET=generate-with-python-scripts-generate-secrets-py
JWT_SECRET=generate-with-python-scripts-generate-secrets-py

# ── Storage Configuration ────────────────────────────────────
# Options: local, s3, render_disk
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage

# For S3/R2 storage:
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=us-east-1
# S3_BUCKET=resumes
# S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com

# For Render Disk storage:
# STORAGE_TYPE=render_disk
# RENDER_DISK_PATH=/opt/render/project/data/storage

# ── App URLs ──────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173
# S1: Set API_PUBLIC_URL for httpOnly cookie auth. Magic links use /auth/verify-magic.
# Local: http://localhost:8000  |  Prod: https://sorce-api.onrender.com
API_PUBLIC_URL=http://localhost:8000

# ── Agent Config ──────────────────────────────────────────────
AGENT_ENABLED=true

# ── Email (Resend) ───────────────────────────────────────────
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=JobHuntin <noreply@jobhuntin.com>

# ── CAPTCHA (Bot Protection) ─────────────────────────────────
# RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
# HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key
# TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# CAPTCHA_PROVIDER=recaptcha  # Options: recaptcha, hcaptcha, turnstile
# CAPTCHA_MIN_SCORE=0.5

# ── Magic Link Security (H2: IP Binding) ─────────────────────
# Enable IP binding to prevent magic link theft attacks
# When enabled, magic links can only be used from the IP that requested them
# RECOMMENDED: Set to true in production for enhanced security
# MAGIC_LINK_BIND_TO_IP=true

# ── Observability ────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ── Alerting v2 (M10: PagerDuty/Opsgenie Integration) ───────
# PagerDuty integration key (Events API v2 routing key)
# PAGERDUTY_API_KEY=your-pagerduty-routing-key
# PAGERDUTY_SERVICE_ID=your-service-id

# Opsgenie integration (alternative/complement to PagerDuty)
# OPSGENIE_API_KEY=your-opsgenie-api-key
# OPSGENIE_API_URL=https://api.opsgenie.com/v2/alerts  # Optional, defaults to Opsgenie API

# ── Worker ───────────────────────────────────────────────────
BROWSERLESS_URL=
BROWSERLESS_TOKEN=
BROWSER_POOL_SIZE=1

# ── JobSpy (job scraping) ─────────────────────────────────────
# JOBSPY_PROXIES=http://user:pass@host:port,http://...
# JOBSPY_USE_FREE_PROXIES=false  # When true, fetch from GimmeProxy/PubProxy when no proxies configured
# JOBSPY_SOURCES=indeed,linkedin,zip_recruiter,glassdoor
# JOBSPY_RESULTS_PER_SOURCE=50
# JOBSPY_HOURS_OLD=168

# ── SonarQube / SonarCloud ────────────────────────────────────
# For SonarCloud: Create token at https://sonarcloud.io/account/security
# For SonarQube Server: Create token in your instance
# SONAR_TOKEN=your-sonar-token
# SONAR_ORGANIZATION=your-org-key
# SONAR_PROJECT_KEY=your-project-key
