{
  "name": "sorce-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "mobile"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "sonar": "sonar-scanner",
    "sonar:dry": "sonar-scanner -Dsonar.scanner.dumpToFile=sonar-report.json",
    "lint:python": "bash scripts/lint-python.sh"
  },
  "devDependencies": {
    "@sonar/scan": "^4.3.4",
    "turbo": "^1.10.0"
  },
  "overrides": {
    "@types/react": "18.2.43",
    "@types/react-dom": "18.2.17"
  }
}
